{
  "name": "@nest-mcp/example-openapi-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Example: convert any OpenAPI 3.x doc into MCP tools that proxy to the upstream",
  "bin": {
    "example-openapi-mcp": "dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "tsc --outDir dist && node dist/main.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@nest-mcp/common": "workspace:*",
    "@nest-mcp/openapi-mcp": "workspace:*",
    "@nest-mcp/server": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "openapi-types": "^12.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
