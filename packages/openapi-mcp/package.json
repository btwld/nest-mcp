{
  "name": "@nest-mcp/openapi-mcp",
  "version": "0.1.0",
  "description": "Convert any OpenAPI 3.x document into MCP tools that proxy to the upstream HTTP API",
  "license": "BSD-3-Clause",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./standalone": {
      "types": "./dist/standalone/index.d.ts",
      "default": "./dist/standalone/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.js.map",
    "!dist/**/*.d.ts.map"
  ],
  "keywords": [
    "nestjs",
    "nest",
    "mcp",
    "model-context-protocol",
    "openapi",
    "swagger",
    "ai",
    "llm",
    "typescript"
  ],
  "homepage": "https://github.com/btwld/nest-mcp#openapi-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/btwld/nest-mcp",
    "directory": "packages/openapi-mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nest-mcp/common": "workspace:*",
    "@nest-mcp/server": "workspace:*",
    "openapi-types": "^12.1.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": ">=0.1.13",
    "rxjs": "^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^4.0.0"
  }
}
