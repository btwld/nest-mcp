{
  "name": "@nest-mcp/auto-mcp",
  "version": "0.1.0",
  "description": "Auto-expose any NestJS controller as MCP tools via in-process decorator scanning — no @nestjs/swagger required",
  "license": "BSD-3-Clause",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.js.map",
    "!dist/**/*.d.ts.map"
  ],
  "keywords": [
    "nestjs",
    "nest",
    "mcp",
    "model-context-protocol",
    "auto-mcp",
    "ai",
    "llm",
    "typescript"
  ],
  "homepage": "https://github.com/btwld/nest-mcp#auto-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/btwld/nest-mcp",
    "directory": "packages/auto-mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nest-mcp/common": "workspace:*",
    "@nest-mcp/server": "workspace:*"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "class-validator": "^0.14.0",
    "reflect-metadata": ">=0.1.13",
    "rxjs": "^7.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "class-validator": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^4.0.0"
  }
}
